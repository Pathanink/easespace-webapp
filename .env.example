# Firebase configuration

FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Choose ONE method only

# Method 1: Provide path to service account JSON (for local development)
FIREBASE_CREDENTIALS_PATH=your_service_account.json

# Method 2: Provide full JSON string (for server/deployment)
FIREBASE_KEY_JSON=your_service_account_json_string

# Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# Directory that stores your trained AI model
MODEL_DIR=final_model